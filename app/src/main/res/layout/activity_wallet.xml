<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_wallet.xml
    XMR Wallet screen for Kabu-Kabu.
    Mirrors the layout style of activity_monero_wallet.xml from Verzus.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ── Header ──────────────────────────────────────────────────────── -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monero Wallet"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tv_wallet_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Initialising…"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="24dp"/>

        <ProgressBar
            android:id="@+id/wallet_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:layout_marginBottom="24dp"
            android:visibility="visible"/>

        <!-- ── Balance card ─────────────────────────────────────────────── -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOTAL BALANCE"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:letterSpacing="0.12"/>

                <TextView
                    android:id="@+id/tv_xmr_balance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— XMR"
                    android:textAppearance="?attr/textAppearanceHeadlineLarge"
                    android:textColor="?attr/colorPrimary"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorOutlineVariant"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UNLOCKED (SPENDABLE)"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:letterSpacing="0.12"/>

                <TextView
                    android:id="@+id/tv_xmr_unlocked"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— XMR available"
                    android:textAppearance="?attr/textAppearanceTitleLarge"
                    android:textColor="?attr/colorOnSurface"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Receive address ────────────────────────────────────────────── -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YOUR XMR ADDRESS"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_xmr_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading…"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:fontFamily="monospace"
                    android:textIsSelectable="true"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btn_copy_address"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Copy Address"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Escrow info card ───────────────────────────────────────────── -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HOW ESCROW WORKS"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1.  You accept a driver offer — your XMR balance is checked automatically.\n\n2.  A 2-of-2 multisig escrow address is created between you and the driver. Neither party can move funds alone.\n\n3.  Your fare is locked in escrow before the ride starts.\n\n4.  When the ride completes, payment is released to the driver automatically. If cancelled, you are refunded.\n\n5.  All of this happens privately over I2P — no central server."
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:lineSpacingMultiplier="1.5"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Actions ────────────────────────────────────────────────────── -->

        <Button
            android:id="@+id/btn_wallet_refresh"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Refresh Balance"
            android:layout_marginBottom="8dp"/>

    </LinearLayout>
</ScrollView>
