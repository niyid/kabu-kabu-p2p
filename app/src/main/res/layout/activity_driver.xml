<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kabu_bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/kabu_amber"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingTop="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🚗 Driver Mode"
            android:textColor="@color/kabu_text_secondary"
            android:textSize="13sp"
            android:paddingBottom="12dp"/>

        <!-- Privacy badge -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🔒 P2P · No Server · I2P Encrypted"
            android:textColor="@color/privacy_indicator"
            android:textSize="11sp"
            android:paddingBottom="16dp"/>

        <!-- Status row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tvDriverStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/driver_status_offline"
                android:textColor="@color/kabu_text_secondary"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvDriverZone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/driver_zone_initial"
                android:textColor="@color/kabu_text_hint"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Active trip info -->
        <TextView
            android:id="@+id/tvTripInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/kabu_gold"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingBottom="12dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/kabu_divider"
            android:layout_marginBottom="12dp"/>

        <!-- Online toggle -->
        <Button
            android:id="@+id/btnToggleOnline"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_go_online"
            android:textColor="@color/kabu_text_on_amber"
            android:backgroundTint="@color/kabu_amber"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- Trip status update -->
        <Button
            android:id="@+id/btnUpdateStatus"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/btn_status_idle"
            android:textColor="@color/kabu_amber"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="20dp"/>

        <!-- Open requests header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_open_requests"
            android:textColor="@color/kabu_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRequests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>

    </LinearLayout>
</ScrollView>
