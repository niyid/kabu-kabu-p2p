<?xml version="1.0" encoding="utf-8"?>
<!--
    data_extraction_rules.xml — Android 12+ (API 31+)

    Prevents both cloud backup AND device-to-device transfer of trip data,
    I2P identity material, and device preferences.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database"   path="kabu_kabu.db"/>
        <exclude domain="database"   path="kabu_kabu.db-shm"/>
        <exclude domain="database"   path="kabu_kabu.db-wal"/>
        <exclude domain="sharedpref" path="com.techducat.kabukabup2p.Prefs.xml"/>
        <exclude domain="file"       path="i2p/"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="database"   path="kabu_kabu.db"/>
        <exclude domain="sharedpref" path="com.techducat.kabukabup2p.Prefs.xml"/>
        <exclude domain="file"       path="i2p/"/>
    </device-transfer>
</data-extraction-rules>
