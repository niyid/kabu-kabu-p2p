<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/kabu_surface"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="6dp">

            <TextView
                android:id="@+id/tvVehicleType"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/kabu_amber"
                android:textStyle="bold"
                android:textSize="15sp"
                android:text="Car"/>

            <TextView
                android:id="@+id/tvRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/kabu_gold"
                android:textSize="14sp"
                android:text="★ 4.5"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tvEta"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/kabu_text_secondary"
                android:textSize="13sp"
                android:text="ETA: 5 min"/>

            <TextView
                android:id="@+id/tvFare"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/kabu_text_primary"
                android:textStyle="bold"
                android:textSize="14sp"
                android:text="₦500"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvDriverZone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/kabu_text_hint"
            android:textSize="11sp"
            android:paddingBottom="10dp"
            android:text="Driver ID: …a1b2c3d4"/>

        <Button
            android:id="@+id/btnAcceptOffer"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="@string/btn_accept"
            android:textColor="@color/kabu_text_on_amber"
            android:backgroundTint="@color/kabu_amber"
            android:textStyle="bold"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
