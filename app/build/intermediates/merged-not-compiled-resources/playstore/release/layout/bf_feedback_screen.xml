<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/root_vg"
    android:background="@color/feedback_background"
    android:orientation="vertical">

    <RelativeLayout
        android:id="@+id/appbar_rl"
        android:background="@color/feedback_appbar_background"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:elevation="4dp"
        tools:targetApi="lollipop">

        <ImageView
            android:id="@+id/close_iv"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:layout_marginLeft="16dp"
            android:layout_marginStart="16dp"
            android:scaleType="centerInside"
            android:src="@drawable/bf_ic_close" />

        <TextView
            android:textColor="@color/feedback_appbar_title"
            android:id="@+id/title_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginLeft="32dp"
            android:layout_marginStart="32dp"
            android:layout_toEndOf="@+id/close_iv"
            android:layout_toLeftOf="@+id/positive_action_tv"
            android:layout_toRightOf="@+id/close_iv"
            android:layout_toStartOf="@+id/positive_action_tv"
            android:ellipsize="end"
            android:lines="1"
            android:maxLines="1"
            android:textSize="20dp"
            tools:ignore="SpUsage"
            tools:text="Feedback" />

        <TextView
            android:textColor="@color/feedback_appbar_action_button"
            android:id="@+id/positive_action_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:layout_alignParentRight="true"
            android:layout_alignParentTop="true"
            android:gravity="center"
            android:paddingEnd="16dp"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingStart="16dp"
            android:textAllCaps="true"
            android:textStyle="bold"
            tools:ignore="UnusedAttribute"
            tools:text="Send" />
    </RelativeLayout>

    <TextView
        android:id="@+id/message_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/appbar_rl"
        android:paddingBottom="24dp"
        android:paddingEnd="24dp"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingStart="24dp"
        android:paddingTop="24dp"
        android:textColor="@color/feedback_text"
        android:textSize="16sp"
        tools:text="Thanks to your Feedback we can continue improving our product" />

    <EditText
        android:id="@+id/feedback_title_et"
        android:layout_below="@+id/message_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/feedback_input_text"
        android:layout_marginBottom="8dp"
        android:background="@color/feedback_input_background"
        android:inputType="text"
        android:paddingBottom="10dp"
        android:paddingEnd="24dp"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingStart="24dp"
        android:paddingTop="10dp"
        android:textColorHint="@color/feedback_input_hint"
        android:textSize="14sp"
        tools:hint="Subject of your Feedback" />

    <EditText
        android:id="@+id/feedback_message_et"
        android:layout_below="@+id/feedback_title_et"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/bugfender_tv"
        android:textColor="@color/feedback_input_text"
        android:background="@color/feedback_input_background"
        android:gravity="top"
        android:inputType="textMultiLine"
        android:paddingBottom="10dp"
        android:paddingEnd="24dp"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingStart="24dp"
        android:paddingTop="10dp"
        android:textColorHint="@color/feedback_input_hint"
        android:textSize="14sp"
        tools:hint="Your Feedback" />

    <TextView
        android:id="@+id/bugfender_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:drawableLeft="@drawable/bf_bugfender_logo"
        android:drawablePadding="8dp"
        android:drawableStart="@drawable/bf_bugfender_logo"
        android:gravity="center"
        android:paddingBottom="8dp"
        android:paddingEnd="24dp"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingStart="24dp"
        android:paddingTop="8dp"
        android:text="@string/powered_by_bugfender"
        android:textColor="@color/feedback_text"
        android:textSize="12sp" />

</RelativeLayout>